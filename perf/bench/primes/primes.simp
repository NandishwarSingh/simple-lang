// Benchmark: count primes below 3000000 by trial division — arithmetic + branches.
fn is_prime(n: int) -> bool {
    if (n < 2) { return false; }
    let mut d = 2;
    while (d * d <= n) {
        if (n % d == 0) { return false; }
        d = d + 1;
    }
    return true;
}

fn main() {
    let mut count = 0;
    let mut n = 2;
    while (n < 3000000) {
        if (is_prime(n)) { count = count + 1; }
        n = n + 1;
    }
    print(count);
}
